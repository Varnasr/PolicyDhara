---
interface Props {
  id: string;
  title: string;
  description?: string;
  link?: string;
  date: string;
  source_short: string;
  sectors: string[];
  type: string;
}

const { id, title, description, link, date, source_short, sectors, type } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const detailHref = `${base}policies/${id}/`;

function getSectorSlug(sector: string): string {
  return sector.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return dateStr; }
}

function getRelativeTime(dateStr: string): string {
  try {
    const d = new Date(dateStr);
    const now = new Date();
    const diffDays = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays === 0) return 'Today';
    if (diffDays === 1) return 'Yesterday';
    if (diffDays < 7) return `${diffDays}d ago`;
    if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
    return formatDate(dateStr);
  } catch { return dateStr; }
}
---
<article class="policy-card" data-sectors={JSON.stringify(sectors.map(getSectorSlug))} data-type={type} data-source={source_short} data-date={date} data-id={id}>
  <div class="policy-card-header">
    <h3 class="policy-title">
      <a href={detailHref}>{title}</a>
    </h3>
  </div>

  <div class="policy-meta">
    <span class="policy-date" title={formatDate(date)}>{getRelativeTime(date)}</span>
    <span class="meta-dot"></span>
    <span class="policy-source">{source_short}</span>
    <span class={`policy-type type-${type}`}>{type}</span>
  </div>

  {description && (
    <p class="policy-description">{description}</p>
  )}

  <div class="policy-sectors">
    {sectors.map(sector => (
      <a href={`${base}sectors/${getSectorSlug(sector)}/`} class="sector-badge">
        {sector}
      </a>
    ))}
  </div>
</article>
