---
import { getAllPolicies } from '../lib/data';

interface Props {
  totalPolicies: number;
  totalSources: number;
  totalSectors: number;
  lastUpdated: string;
}

const { totalPolicies, totalSources, totalSectors, lastUpdated } = Astro.props;
const policies = getAllPolicies();
const dates = policies.map(p => p.date).sort();
const earliestYear = dates[0]?.slice(0, 4) || '—';
const latestYear = dates[dates.length - 1]?.slice(0, 4) || '—';

function formatUpdated(isoStr: string): string {
  try {
    const d = new Date(isoStr);
    return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch {
    return 'Recently';
  }
}
---
<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-number">{totalPolicies}</div>
    <div class="stat-label">Policies Tracked</div>
  </div>
  <div class="stat-card">
    <div class="stat-number">{earliestYear}–{latestYear}</div>
    <div class="stat-label">Coverage Span</div>
  </div>
  <div class="stat-card">
    <div class="stat-number">{totalSources}</div>
    <div class="stat-label">Open Sources</div>
  </div>
  <div class="stat-card">
    <div class="stat-number">{totalSectors}</div>
    <div class="stat-label">Sectors</div>
  </div>
  <div class="stat-card">
    <div class="stat-number" style="font-size: 1.125rem;">{formatUpdated(lastUpdated)}</div>
    <div class="stat-label">Last Updated</div>
  </div>
</div>
